# ============ 周边可视化系统 后端配置 ============
# 拷贝本文件为 .env，填入你自己的值（.env 不要提交 git）

# 服务端口
PORT=3000
HOST=0.0.0.0

# ============ 数据库（填你自己的 MySQL）============
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=goods_visualization
DB_USER=root
DB_PASSWORD=

# ============ JWT 密钥（随便填一串随机字符，用于登录 token 加密）============
JWT_SECRET=请改成一串你自己的随机字符串

# ============ 文件上传 ============
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760

# ============ AI 视觉分析配置（读图+总结帖子内容）============
# 用于"AI分析图片内容"功能。找 xxwf 要密钥，或填你自己的。
# 没填则 AI 分析功能不可用（不影响其它功能）。
AI_API_KEY=
AI_BASE_URL=
AI_OCR_MODEL=qwen-vl-ocr
AI_TEXT_MODEL=glm-5.2
